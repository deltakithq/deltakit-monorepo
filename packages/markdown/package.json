{
	"name": "@deltakit/markdown",
	"version": "0.2.5",
	"description": "Stream markdown in AI chat without flicker or broken syntax",
	"homepage": "https://deltakit.dev",
	"type": "module",
	"license": "MIT",
	"author": "DeltaKit HQ",
	"repository": {
		"type": "git",
		"url": "https://github.com/deltakithq/deltakit-monorepo",
		"directory": "packages/markdown"
	},
	"keywords": [
		"deltakit",
		"markdown",
		"streaming",
		"ai",
		"react",
		"sse",
		"llm"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./core": {
			"types": "./dist/core/index.d.ts",
			"import": "./dist/core/index.js",
			"require": "./dist/core/index.cjs"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"check": "biome check src/",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"bench": "vitest bench",
		"bench:save": "vitest bench --outputJson benchmarks/results/latest.json",
		"clean": "rm -rf dist"
	},
	"devDependencies": {
		"@testing-library/react": "^16.3.0",
		"@types/react": "^18.3.18",
		"@types/react-dom": "^18.3.5",
		"jsdom": "^28.1.0",
		"micromark": "^4.0.0",
		"react-markdown": "^10.1.0",
		"remark-parse": "^11.0.0",
		"unified": "^11.0.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"tsup": "8.5.1",
		"typescript": "^5.7.2",
		"vitest": "^3.0.5"
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0"
	},
	"sideEffects": false
}
